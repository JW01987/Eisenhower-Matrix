<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.todo.mapper.UserMapper">
<!-- 회원가입 -->
 <insert id="signUp" parameterType="User" 
        useGeneratedKeys="true" keyProperty="userId">
    INSERT INTO user (username, login_id, password)
    VALUES (#{username}, #{loginId}, #{password})
</insert>

<!-- 로그인 -->
<select id="findByLoginId" resultType="User" parameterType="String">
    SELECT * FROM user
    WHERE login_id = #{loginId}
</select>

<!-- 회원정보 조회 -->
<select id="findById" resultType="User" parameterType="Long">
    SELECT * FROM user
    WHERE user_id = #{userId}
</select>

<!-- 회원 정보 수정 -->
<update id="updateUserName" parameterType="User">
    UPDATE user
    SET username = #{username}
    WHERE user_id = #{userId}
</update>

<!-- 회원 탈퇴 -->
<delete id="deleteUser" parameterType="Long">
    DELETE FROM user
    WHERE user_id = #{userId}
</delete>
</mapper>