<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.todo.mapper.TopicMapper">
    <!-- 토픽생성 -->
    <insert id="createTopic" parameterType="Topic" useGeneratedKeys="true" keyProperty="topicId">
    INSERT INTO topic (user_id, title)
    VALUES (#{userId}, #{title});
    </insert>

    <!-- 토픽조회 -->
    <select id="findByUserId" resultType="Topic" parameterType="Long">
        SELECT * FROM topic
        WHERE user_id = #{userId}
    </select>

    <select id="findByTopicId" resultType="Topic" parameterType="map">
        SELECT * FROM topic
        WHERE user_id = #{userId} AND topic_id = #{topicId}
    </select>

    <!-- 토픽 수정 -->
    <update id="updateTopic" parameterType="Topic">
        UPDATE topic
        SET title = #{title}
        WHERE topic_id = #{topicId}
    </update>

    <!-- 토픽 삭제 -->
    <delete id="deleteTopic" parameterType="Long">
        DELETE FROM topic
        WHERE topic_id = #{topicId}
    </delete>
</mapper>